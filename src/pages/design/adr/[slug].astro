---
import BibleLayout from '../../../layouts/BibleLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('adr');
  return entries.map(entry => ({
    params: { slug: entry.id.replace('.md', '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<BibleLayout title={`ADR-${String(entry.data.id).padStart(4, '0')}: ${entry.data.title}`}>
  <article>
    <Content />
  </article>
</BibleLayout>
