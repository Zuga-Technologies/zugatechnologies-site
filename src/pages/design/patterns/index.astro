---
import BibleLayout from '../../../layouts/BibleLayout.astro';
import { getCollection } from 'astro:content';
const entries = (await getCollection('patterns')).sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<BibleLayout title="Bible Patterns">
  <h1 style="font-size: var(--type-scale-5xl); font-weight: var(--font-weight-bold);">Patterns</h1>
  <p style="color: var(--text-secondary); font-size: var(--type-scale-lg); margin-bottom: var(--space-8);">
    {entries.length} interaction patterns in the Zuga design system.
  </p>
  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2);">
    {entries.map(p => (
      <li>
        <a
          href={`/design/patterns/${p.id.replace('.md', '')}`}
          style="display: flex; align-items: baseline; gap: var(--space-3); padding: var(--space-3) var(--space-4); border: 1px solid var(--border-subtle); border-radius: var(--radius-md); background: var(--surface-primary); text-decoration: none; color: inherit;"
        >
          <span style="font-size: var(--type-scale-base); font-weight: var(--font-weight-semibold); color: var(--text-primary);">{p.data.name}</span>
          <span style="font-size: var(--type-scale-sm); color: var(--text-secondary);">{p.data.summary}</span>
        </a>
      </li>
    ))}
  </ul>
</BibleLayout>
