---
import Container from './Container.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-rule-soft py-12 text-sm text-ink-500">
  <Container class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
    <p>
      © {year} [MIKE-PENDING: legal entity name]. All rights reserved.
    </p>
    <nav class="flex items-center gap-6" aria-label="Footer">
      <a href="/privacy" class="hover:text-ink-300 transition-colors">[MIKE-PENDING: privacy-link-text]</a>
      <a href="/terms" class="hover:text-ink-300 transition-colors">[MIKE-PENDING: terms-link-text]</a>
      <span class="text-ink-700">[MIKE-PENDING: optional social link]</span>
    </nav>
  </Container>
</footer>
