---
import Container from './Container.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-rule-soft py-12 text-sm text-ink-500">
  <Container class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
    <p>
      &copy; {year} Zuga Technologies LLC, a New York limited liability company. All rights reserved.
    </p>
    <nav class="flex items-center gap-6" aria-label="Footer">
      <a href="/privacy" class="hover:text-ink-300 transition-colors">Privacy</a>
      <a href="/terms" class="hover:text-ink-300 transition-colors">Terms</a>
      <a
        href="mailto:buga@zugabot.ai"
        class="hover:text-ink-300 transition-colors"
      >buga@zugabot.ai</a>
    </nav>
  </Container>
</footer>
