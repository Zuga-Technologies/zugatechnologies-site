---
/* Reusable canvas-based particle field. Drop inside any section that has
   `position: relative; overflow: hidden` and pair with `relative z-10` on
   the foreground content. Script is hoisted by Astro and runs once per
   page — handles every canvas marked with `data-particle-field`. */
interface Props {
  count?: number;
  minSpeed?: number;
  maxSpeed?: number;
  minSize?: number;
  maxSize?: number;
  baseOpacityMin?: number;
  baseOpacityMax?: number;
  mouseRadius?: number;
  mouseAttraction?: number;
  hoverGlow?: number;
  color?: string; // 'r,g,b' string for rgba(...) template
}

const {
  count = 55,
  minSpeed = 0.04,
  maxSpeed = 0.12,
  minSize = 1.0,
  maxSize = 2.2,
  baseOpacityMin = 0.22,
  baseOpacityMax = 0.52,
  mouseRadius = 220,
  mouseAttraction = 0.025,
  hoverGlow = 0.7,
  color = '78,162,192',
} = Astro.props;
---

<canvas
  data-particle-field
  data-count={count}
  data-min-speed={minSpeed}
  data-max-speed={maxSpeed}
  data-min-size={minSize}
  data-max-size={maxSize}
  data-base-opacity-min={baseOpacityMin}
  data-base-opacity-max={baseOpacityMax}
  data-mouse-radius={mouseRadius}
  data-mouse-attraction={mouseAttraction}
  data-hover-glow={hoverGlow}
  data-color={color}
  class="pointer-events-none absolute inset-0 h-full w-full opacity-0 transition-opacity duration-700"
  aria-hidden="true"
></canvas>

<script>
  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    size: number;
    baseOpacity: number;
    opacity: number;
  }

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const canvases = document.querySelectorAll<HTMLCanvasElement>('canvas[data-particle-field]');
    canvases.forEach((canvas) => initField(canvas));
  }

  function initField(canvas: HTMLCanvasElement) {
    const host = canvas.parentElement as HTMLElement | null;
    if (!host) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const cfg = {
      count: Number(canvas.dataset.count) || 55,
      minSpeed: Number(canvas.dataset.minSpeed) || 0.04,
      maxSpeed: Number(canvas.dataset.maxSpeed) || 0.12,
      minSize: Number(canvas.dataset.minSize) || 1.0,
      maxSize: Number(canvas.dataset.maxSize) || 2.2,
      baseOpacityMin: Number(canvas.dataset.baseOpacityMin) || 0.22,
      baseOpacityMax: Number(canvas.dataset.baseOpacityMax) || 0.52,
      mouseRadius: Number(canvas.dataset.mouseRadius) || 220,
      mouseAttraction: Number(canvas.dataset.mouseAttraction) || 0.025,
      hoverGlow: Number(canvas.dataset.hoverGlow) || 0.7,
      color: canvas.dataset.color || '78,162,192',
    };

    let particles: Particle[] = [];
    const mouse = { x: -9999, y: -9999, active: false };
    let dpr = window.devicePixelRatio || 1;
    let width = 0, height = 0;
    let raf = 0;
    let visible = false;

    function resize() {
      const r = host!.getBoundingClientRect();
      width = r.width; height = r.height;
      canvas.width = Math.max(1, Math.floor(width * dpr));
      canvas.height = Math.max(1, Math.floor(height * dpr));
      canvas.style.width = width + 'px';
      canvas.style.height = height + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (particles.length === 0) seed();
    }

    function seed() {
      particles = [];
      for (let i = 0; i < cfg.count; i++) {
        const a = Math.random() * Math.PI * 2;
        const s = cfg.minSpeed + Math.random() * (cfg.maxSpeed - cfg.minSpeed);
        const baseOpacity = cfg.baseOpacityMin + Math.random() * (cfg.baseOpacityMax - cfg.baseOpacityMin);
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          vx: Math.cos(a) * s,
          vy: Math.sin(a) * s,
          size: cfg.minSize + Math.random() * (cfg.maxSize - cfg.minSize),
          baseOpacity,
          opacity: baseOpacity,
        });
      }
    }

    function step() {
      ctx!.clearRect(0, 0, width, height);
      for (const p of particles) {
        if (mouse.active) {
          const dx = mouse.x - p.x;
          const dy = mouse.y - p.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist > 0 && dist < cfg.mouseRadius) {
            const force = (cfg.mouseRadius - dist) / cfg.mouseRadius;
            p.vx += (dx / dist) * force * cfg.mouseAttraction;
            p.vy += (dy / dist) * force * cfg.mouseAttraction;
            const target = Math.min(0.95, p.baseOpacity + force * cfg.hoverGlow);
            p.opacity += (target - p.opacity) * 0.15;
          } else {
            p.opacity += (p.baseOpacity - p.opacity) * 0.06;
          }
        } else {
          p.opacity += (p.baseOpacity - p.opacity) * 0.06;
        }

        p.vx *= 0.985;
        p.vy *= 0.985;
        const sp = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (sp < cfg.minSpeed) {
          const a = sp > 0 ? Math.atan2(p.vy, p.vx) : Math.random() * Math.PI * 2;
          p.vx = Math.cos(a) * cfg.minSpeed;
          p.vy = Math.sin(a) * cfg.minSpeed;
        }
        p.x += p.vx; p.y += p.vy;

        if (p.x < -5) p.x = width + 5;
        if (p.x > width + 5) p.x = -5;
        if (p.y < -5) p.y = height + 5;
        if (p.y > height + 5) p.y = -5;

        ctx!.fillStyle = `rgba(${cfg.color}, ${p.opacity})`;
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx!.fill();
      }
      raf = requestAnimationFrame(step);
    }

    const ro = new ResizeObserver(() => resize());
    ro.observe(host);
    window.addEventListener('resize', () => { dpr = window.devicePixelRatio || 1; resize(); });

    host.addEventListener('mousemove', (e) => {
      const r = host.getBoundingClientRect();
      mouse.x = e.clientX - r.left;
      mouse.y = e.clientY - r.top;
      mouse.active = true;
    });
    host.addEventListener('mouseleave', () => { mouse.active = false; });

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting && !visible) {
          visible = true;
          canvas.style.opacity = '1';
          if (!raf) step();
        } else if (!e.isIntersecting && visible) {
          visible = false;
          canvas.style.opacity = '0';
          cancelAnimationFrame(raf); raf = 0;
        }
      }
    }, { threshold: 0.05 });
    io.observe(host);

    resize();
  }
</script>
