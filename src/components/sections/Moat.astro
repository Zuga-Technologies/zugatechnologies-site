---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import ParticleField from '../ParticleField.astro';

/* Three pillars that demonstrate the moat (data gravity + ship speed +
   interpretability) without naming it. Mike has hard veto; named-moat
   language and "Anthropic" stay out of the public copy. */
const pillars = [
  {
    title: 'One platform, every studio',
    body: 'Identity, payments, memory, and AI routing live in a shared canonical layer. New products inherit the whole stack on day one — and feed the same memory back. The platform compounds with every studio that ships.',
  },
  {
    title: 'Built to ship daily',
    body: 'Autonomous agents work the codebase around the clock under hard guardrails and a multi-layer safety system. Releases land in days, not quarters. The changelog is the roadmap.',
  },
  {
    title: 'Mechanistic by default',
    body: 'Every agent thought, decision, cost, and file change is observable in real time. No black box — full audit trail by default.',
  },
];
---

<Section id="moat" class="relative overflow-hidden">
  <ParticleField />
  <Container class="relative z-10">
    <div class="max-w-narrow">
      <Eyebrow>How we build</Eyebrow>
      <h2 class="mt-6 text-3xl font-semibold tracking-tight leading-[1.15] text-ink-100 sm:text-4xl">
        Compounding leverage, in the open
      </h2>
      <p class="mt-6 leading-relaxed text-ink-300">
        Every product on the platform shares one identity, one wallet, one memory, one safety layer. New studios inherit the whole stack on day one — and contribute back to it.
      </p>
    </div>

    <dl class="mt-16 grid grid-cols-1 gap-x-12 gap-y-12 lg:grid-cols-3">
      {pillars.map((p, i) => (
        <div>
          <dt class="flex items-baseline gap-3">
            <span class="font-mono text-xs text-accent-500">0{i + 1}</span>
            <span class="text-base font-semibold text-ink-100">{p.title}</span>
          </dt>
          <dd class="mt-5 text-sm leading-relaxed text-ink-400">{p.body}</dd>
        </div>
      ))}
    </dl>
  </Container>
</Section>
