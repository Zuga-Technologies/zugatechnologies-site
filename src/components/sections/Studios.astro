---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';

const tiles = [
  {
    name: 'ZugaLife',
    body: 'A wellness companion that tracks habits, mood, and fitness — with an AI coach that actually pays attention.',
    status: 'Launching',
  },
  {
    name: 'ZugaGamerOverlay',
    body: 'A real-time overlay for streamers and competitive gamers — AI-driven moments, overlays you don’t have to babysit.',
    status: 'Launching',
  },
  {
    name: 'More products soon',
    body: 'A growing pipeline across health, trading, code, and creative tools. Built in the open.',
    status: 'In build',
  },
];
---

<Section variant="muted" id="what">
  <Container>
    <div data-reveal="left">
    <div class="max-w-narrow">
      <Eyebrow>Shipping now</Eyebrow>
      <h2 class="mt-6 text-3xl font-semibold tracking-tight leading-[1.15] text-ink-100 sm:text-4xl">
        The product line for the agent era.
      </h2>
      <p class="mt-6 leading-relaxed text-ink-300">
        Two live today. Many in the pipeline. Each one an opinionated bet on what software looks like when AI is a first-class participant — not a feature bolted onto something else.
      </p>
    </div>

    <ul class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {tiles.map((tile) => (
        <li class="studio-tile rounded-lg border border-rule bg-ink-950 p-6">
          <div class="flex items-start justify-between gap-4">
            <h3 class="text-base font-semibold text-ink-100">{tile.name}</h3>
            <span class="rounded-full border border-rule px-2 py-0.5 text-[10px] uppercase tracking-wider text-ink-400">
              {tile.status}
            </span>
          </div>
          <p class="mt-3 text-sm text-ink-400">{tile.body}</p>
        </li>
      ))}
    </ul>
    </div>
  </Container>
</Section>
