---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';
---

<Section variant="hero" size="lg" id="hero">
  <Container width="narrow">
    <Eyebrow>[MIKE-PENDING: hero-eyebrow]</Eyebrow>
    <h1 class="mt-5 text-balance text-4xl font-semibold tracking-tight text-ink-100 sm:text-5xl lg:text-6xl">
      [MIKE-PENDING: hero-headline]
    </h1>
    <p class="mt-6 text-pretty text-lg text-ink-300">
      [MIKE-PENDING: hero-subheadline]
    </p>
    {/* href values intentionally `#` so accidental clicks during Mike review don't 404.
        Real targets [MIKE-PENDING: hero-primary-cta-href] + [MIKE-PENDING: hero-secondary-cta-href]
        are still tracked here for audit grep. */}
    <div class="mt-10 flex flex-wrap items-center gap-3">
      <Button variant="primary" href="#">
        [MIKE-PENDING: hero-primary-cta-label]
      </Button>
      <Button variant="secondary" href="#">
        [MIKE-PENDING: hero-secondary-cta-label]
      </Button>
    </div>
  </Container>
</Section>
