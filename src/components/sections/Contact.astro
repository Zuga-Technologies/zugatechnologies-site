---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

/* Email-only contact — no <form>, no data collection (Mike's hard-veto lane:
   privacy / GDPR). mailto: routes directly to founder; lowest-surface way to
   give partners a path in without standing up a backend or third-party deps.
   Pre-filled subject + body give visitors a starting structure they can edit. */
const contactEmail = 'buga@zugabot.ai';
const subject = 'Hello from zugatechnologies.com';
const body = [
  'Hi Buga,',
  '',
  'I came across Zuga Technologies and wanted to reach out.',
  '',
  'A bit about me:',
  '',
  '',
  "What I'd like to discuss:",
  '',
  '',
  'Thanks,',
  '',
].join('\n');

const mailtoHref = `mailto:${contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
---

<Section id="contact" size="lg">
  <Container width="narrow">
    <Eyebrow>Get in touch</Eyebrow>
    <h2 class="mt-6 text-3xl font-semibold tracking-tight leading-[1.15] text-ink-100 sm:text-4xl">
      Talk to us
    </h2>
    <p class="mt-6 leading-relaxed text-ink-300">
      Investors, partners, and builders welcome. Email goes straight to a founder — no forms, no funnels.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <Button variant="primary" href={mailtoHref}>
        Contact {contactEmail}
      </Button>
    </div>
  </Container>
</Section>
