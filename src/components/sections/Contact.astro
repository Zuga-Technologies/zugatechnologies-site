---
import Section from '../Section.astro';
import Container from '../Container.astro';
import Eyebrow from '../Eyebrow.astro';
import Button from '../Button.astro';

/* Email + optional scheduling link. NO <form> — form-submit + data-collection are
   Mike's hard-veto lane (privacy/GDPR). mailto: link is the lowest-surface way
   to give partners a path in without standing up backend or third-party deps.
   Email alias is [MIKE-PENDING] — could be hello@, investors@, partners@, or
   route through Mike personally. */
---

<Section id="contact" size="lg">
  <Container width="narrow">
    <Eyebrow>[MIKE-PENDING: contact-eyebrow]</Eyebrow>
    <h2 class="mt-4 text-3xl font-semibold tracking-tight text-ink-100 sm:text-4xl">
      [MIKE-PENDING: contact-heading]
    </h2>
    <p class="mt-5 text-ink-300">
      [MIKE-PENDING: contact-body]
    </p>
    <div class="mt-10 flex flex-wrap items-center gap-3">
      <Button variant="primary" href="mailto:[MIKE-PENDING: contact-email-address]">
        [MIKE-PENDING: contact-email-cta-label]
      </Button>
      <span class="text-sm text-ink-500">
        [MIKE-PENDING: optional secondary contact channel — calendar / DM / nothing]
      </span>
    </div>
  </Container>
</Section>
