---
interface Props {
  profile: string;
  consumer: string;
  family: string;
  accentRamp: string;
}
const { profile, consumer, family, accentRamp } = Astro.props;
---
<a href={`/design/profiles/${profile}`} style={`display: block; border: 1px solid var(--border-default); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface-primary); text-decoration: none; color: inherit;`}>
  <div style={`height: var(--space-6); background: var(--color-${accentRamp}-500);`}></div>
  <div style={`padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1);`}>
    <span style={`font-size: var(--type-scale-base); font-weight: var(--font-weight-semibold); color: var(--text-primary);`}>
      {consumer}
    </span>
    <code style={`font-size: var(--type-scale-xs); font-family: var(--font-family-mono); color: var(--text-secondary);`}>
      {profile}
    </code>
    <span style={`display: inline-block; margin-top: var(--space-1); padding: var(--space-0_5) var(--space-2); background: var(--surface-secondary); border-radius: var(--radius-sm); font-size: var(--type-scale-xs); color: var(--text-tertiary);`}>
      {family}
    </span>
  </div>
</a>
