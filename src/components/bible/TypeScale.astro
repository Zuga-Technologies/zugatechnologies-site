---
interface Props {
  size: string;
  label: string;
  sample?: string;
}
const { size, label, sample = 'The quick brown fox jumps over the lazy dog' } = Astro.props;
---
<div style={`display: flex; align-items: baseline; gap: var(--space-4); padding: var(--space-3) 0; border-bottom: 1px solid var(--border-subtle);`}>
  <span style={`width: 9rem; flex-shrink: 0; font-size: var(--type-scale-xs); color: var(--text-secondary); font-family: var(--font-family-mono);`}>
    {label}
  </span>
  <span style={`flex: 1; font-size: var(${size}); color: var(--text-primary); line-height: var(--font-line-height-snug); overflow: hidden; white-space: nowrap; text-overflow: ellipsis;`}>
    {sample}
  </span>
  <code style={`flex-shrink: 0; font-size: var(--type-scale-xs); color: var(--text-tertiary); font-family: var(--font-family-mono);`}>
    {size}
  </code>
</div>
